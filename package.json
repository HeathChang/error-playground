{
  "name": "error-playground",
  "version": "0.0.0",
  "description": "에러 페이지(404/500)를 가벼운 인터랙션으로 바꾸는 프레임워크 독립 경량 임베드 라이브러리",
  "type": "module",
  "main": "./dist/error-playground.js",
  "module": "./dist/error-playground.js",
  "types": "./dist/types/core/index.d.ts",
  "unpkg": "./dist/error-playground.iife.js",
  "exports": {
    ".": {
      "types": "./dist/types/core/index.d.ts",
      "import": "./dist/error-playground.js"
    }
  },
  "files": ["dist"],
  "sideEffects": ["**/error-playground.js", "**/error-playground.iife.js"],
  "scripts": {
    "dev": "vite",
    "build": "vite build && tsc -p tsconfig.build.json",
    "prepare": "npm run build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "size": "node scripts/size.mjs"
  },
  "keywords": ["404", "500", "error-page", "embed", "vanilla", "lightweight"],
  "license": "MIT",
  "devDependencies": {
    "jsdom": "^25.0.1",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "vitest": "^2.1.4"
  }
}
